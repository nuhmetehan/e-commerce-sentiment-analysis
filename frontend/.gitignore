# =========================================
# 🐍 PYTHON & MACHINE LEARNING (Arka Uç)
# =========================================
# Python önbellek dosyaları (İşte baş belası olanlar)
__pycache__/
*.py[cod]
*$py.class

# Sanal Ortamlar (Kütüphanelerin kurulu olduğu ağır klasörler)
venv/
env/
.venv/

# Çevresel değişkenler (API şifreleri, gizli anahtarlar)
.env

# Jupyter Notebook geçici dosyaları
.ipynb_checkpoints/

# Veri setleri (GitHub 100MB sınırına takılır, repoda tutulmaz)
*.csv
*.xlsx
"Womens Clothing E-Commerce Reviews.csv"

# =========================================
# ⚛️ NODE.JS & NEXT.JS (Ön Uç - Frontend)
# =========================================
# Node kütüphaneleri (Repoya atılması yasak olan kara delik!)
node_modules/
frontend/node_modules/

# Next.js derleme (build) ve önbellek dosyaları
.next/
frontend/.next/
out/
build/

# Node hata logları
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================================
# 💻 İŞLETİM SİSTEMİ & EDİTÖR DOSYALARI
# =========================================
# Mac ve Windows çöp dosyaları
.DS_Store
Thumbs.db

# VS Code ayarları
.vscode/